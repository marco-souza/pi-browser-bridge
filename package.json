{
  "name": "pi-browser-bridge",
  "type": "module",
  "private": true,
  "workspaces": [
    "logger",
    "protocol",
    "pi-extension",
    "chrome-extension"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@pi-browser-bridge/logger": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/chrome": "^0.1.40"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
